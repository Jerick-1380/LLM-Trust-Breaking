# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
MODEL=gpt-4o-mini
TEMPERATURE=0.7

# OpenRouter Configuration (alternative to OpenAI)
# Set USE_OPENROUTER=true to use OpenRouter instead of OpenAI
USE_OPENROUTER=false
OPENROUTER_API_KEY=your-openrouter-key-here
# Model to use when USE_OPENROUTER=true
# Examples: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Reasoning Model Configuration (only for o1/o3/gpt-5 models)
# Controls how much reasoning the model does before generating output
# Valid values: "low", "medium", "high"
# Higher effort = more reasoning tokens = better quality but slower/more expensive
# Default: "medium"
REASONING_EFFORT=medium

# Game Configuration
NUM_AGENTS=5
DM_ROUNDS=12
